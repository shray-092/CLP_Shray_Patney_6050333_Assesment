<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Employee List</title>
</head>
<body>

<h2>Employee List</h2>

<p th:if="${message != null and !#strings.isEmpty(message)}"
   th:text="${message}"
   style="color:green; font-weight:bold;">
</p>

<table border="1">
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Salary</th>
        <th>Date of Joining</th>
        <th>Department</th>
        <th>Actions</th>
    </tr>
    <tr th:each="emp : ${emps}">
        <td th:text="${emp.empId}"></td>
        <td th:text="${emp.empName}"></td>
        <td th:text="${emp.empSal}"></td>
        <td th:text="${emp.empDoj}"></td>
        <td th:text="${emp.deptName}"></td>
        <td>
            <a th:href="@{/edit/{id}(id=${emp.empId})}">Edit</a>
            |
            <a th:href="@{/delete/{id}(id=${emp.empId})}"
               onclick="return confirm('Are you sure you want to delete?')">Delete</a>
        </td>
    </tr>
</table>

</body>
</html>